<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.c1z4.rentcar.member.model.dao.MemberMapper">
    <resultMap id="levelResultMap" type="com.c1z4.rentcar.member.model.dto.LevelDTO">
        <result property="level" column="LEVEL"/>
        <result property="discountRate" column="DISCOUNT_RATE" />
    </resultMap>

    <resultMap id="memberWithLevelResultMap" type="com.c1z4.rentcar.member.model.dto.MemberDTO">
        <id property="memberCode" column="MEMBER_CODE"/>
        <result property="memberName" column="MEMBER_NAME"/>
        <result property="phone" column="PHONE"/>
        <association property="level" resultMap="levelResultMap" />
    </resultMap>

    <select id="getAllMemberWithLevel" resultMap="memberWithLevelResultMap">
          SELECT M.MEMBER_CODE
                ,M.MEMBER_NAME
                ,M.PHONE
                ,L.LEVEL
                ,L.DISCOUNT_RATE
            FROM TBL_MEMBER M
            JOIN TBL_LEVEL L
           USING (LEVEL)
        ORDER BY M.MEMBER_CODE
    </select>

</mapper>