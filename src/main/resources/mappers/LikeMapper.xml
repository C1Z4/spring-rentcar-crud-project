<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.c1z4.rentcar.like.model.dao.LikeMapper">

    <resultMap id="carLikeResultMap" type="com.c1z4.rentcar.like.model.dto.CarLikeDTO">
        <id column="CAR_CODE" property="carCode"/>
        <id column="CAR_NUMBER" property="carNumber"/>
        <result column="RENT_PRICE" property="rentPrice"/>
        <result column="LIKED" property="liked"/>
    </resultMap>

    <select id="selectCarsWithLike" resultMap="carLikeResultMap" parameterType="_int">
        SELECT  C.CAR_CODE, C.CAR_NUMBER, C.RENT_PRICE,
            CASE WHEN L.MEMBER_CODE IS NULL THEN FALSE ELSE TRUE END AS LIKED
        FROM    TBL_CAR C
            LEFT JOIN TBL_LIKE L
            ON C.CAR_CODE = L.CAR_CODE AND L.MEMBER_CODE = #{ memberCode }
        ORDER BY LIKED DESC
    </select>

    <insert id="insertLike" parameterType="map">
        INSERT INTO TBL_LIKE (MEMBER_CODE, CAR_CODE)
        VALUES (#{memberCode}, #{carCode})
    </insert>

    <delete id="deleteLike" parameterType="map">
        DELETE FROM TBL_LIKE
        WHERE MEMBER_CODE = #{memberCode} AND CAR_CODE = #{carCode}
    </delete>

</mapper>